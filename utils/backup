#!/bin/bash
/usr/bin/auth.sh || exit 1

TG_CONF="/etc/openvpn/tg_backup.conf"
BACKUP_DIR="/root/backup_temp" 

check_credentials() {
    if [ ! -f "$TG_CONF" ]; then
        clear
        echo -e "\033[0;36m┌─────────────────────────────────────────────────────┐\033[0m"
        echo -e " \033[0;32m[!] First Time Setup: Telegram Cloud Backup\033[0m"
        echo -e "\033[0;36m└─────────────────────────────────────────────────────┘\033[0m"
        echo -e " \033[0;33mCRITICAL:\033[0m You MUST press 'Start' on your bot in Telegram"
        echo -e " before it can send you files!\n"
        read -p " Enter Telegram Bot Token : " BOT_TOKEN
        read -p " Enter Telegram Chat ID   : " CHAT_ID
        
        if [[ -n "$BOT_TOKEN" && -n "$CHAT_ID" ]]; then
            echo "BOT_TOKEN=\"$BOT_TOKEN\"" > $TG_CONF
            echo "CHAT_ID=\"$CHAT_ID\"" >> $TG_CONF
            chmod 600 $TG_CONF
        else
            echo -e " \033[0;31m[ERROR] Token and Chat ID cannot be empty!\033[0m"
            sleep 2
            return 1
        fi
    fi
    return 0
}

run_backup() {
    local IS_CRON=$1
    
    if [[ -f /tmp/backup_running ]]; then
        if [[ -n "$(find /tmp/backup_running -mmin +10 2>/dev/null)" ]]; then
            rm -f /tmp/backup_running
        else
            exit 0
        fi
    fi
    touch /tmp/backup_running
    
    if [[ "$IS_CRON" == "cron" ]]; then
        if [ ! -f "$TG_CONF" ]; then rm -f /tmp/backup_running; exit 0; fi
    else
        check_credentials || { rm -f /tmp/backup_running; backup.sh; exit 1; }
    fi
    
    source $TG_CONF
    
    IP=$(curl -sS -4 ifconfig.me)
    DATE=$(date +"%Y-%m-%d_%H-%M")
    FILENAME="OpenVPN_Backup_${IP}_${DATE}.zip"

    [[ "$IS_CRON" != "cron" ]] && echo -e "\n \033[0;32m[+]\033[0m Compiling portable user & system data..."
    
    rm -rf "$BACKUP_DIR"
    mkdir -p "$BACKUP_DIR"/ssh
    mkdir -p "$BACKUP_DIR"/openvpn
    mkdir -p "$BACKUP_DIR"/system

    # Extract PAM Users safely
    awk -F: '$3 >= 1000 && $1 != "nobody" && $7 == "/bin/false" {print $1}' /etc/passwd > "$BACKUP_DIR"/ssh/vpn_users.txt
    touch "$BACKUP_DIR"/ssh/passwd "$BACKUP_DIR"/ssh/shadow "$BACKUP_DIR"/ssh/group "$BACKUP_DIR"/ssh/gshadow
    
    while read user; do
        grep -w "^$user" /etc/passwd >> "$BACKUP_DIR"/ssh/passwd
        grep -w "^$user" /etc/shadow >> "$BACKUP_DIR"/ssh/shadow
        grep -w "^$user" /etc/group >> "$BACKUP_DIR"/ssh/group
        grep -w "^$user" /etc/gshadow >> "$BACKUP_DIR"/ssh/gshadow
    done < "$BACKUP_DIR"/ssh/vpn_users.txt
    
    # Copy Configs
    cp /etc/openvpn/server/server.conf "$BACKUP_DIR"/openvpn/server.conf 2>/dev/null
    cp /root/Universal-Client.ovpn "$BACKUP_DIR"/openvpn/Universal-Client.ovpn 2>/dev/null

    # Scrub IPs to make the backup portable
    sed -i '/^local/d' "$BACKUP_DIR"/openvpn/server.conf 2>/dev/null
    sed -i -E 's/^remote [0-9]+\.[0-9]+\.[0-9]+\.[0-9]+/remote REPLACE_IP/' "$BACKUP_DIR"/openvpn/Universal-Client.ovpn 2>/dev/null

    # Copy System Settings
    [[ -f /etc/openvpn/tg_backup.conf ]] && cp /etc/openvpn/tg_backup.conf "$BACKUP_DIR"/system/
    [[ -f /etc/cron.d/auto_backup ]] && cp /etc/cron.d/auto_backup "$BACKUP_DIR"/system/
    [[ -f /etc/cron.d/auto_reboot ]] && cp /etc/cron.d/auto_reboot "$BACKUP_DIR"/system/
    
    cd "$BACKUP_DIR" || { rm -f /tmp/backup_running; exit; }
    zip -r /root/"$FILENAME" * > /dev/null 2>&1
    cd /root || { rm -f /tmp/backup_running; exit; }
    
    [[ "$IS_CRON" != "cron" ]] && echo -e " \033[0;32m[+]\033[0m Uploading to Google Drive..."
    
    # Push to Google Drive
    rclone copy /root/"$FILENAME" gdrive:/VPS_Backups/
    
    # Generate the raw share link from Google Drive
    RAW_LINK=$(rclone link gdrive:/VPS_Backups/"$FILENAME")
    
    # Convert to Direct Download link
    if [[ "$RAW_LINK" == *"drive.google.com"* ]]; then
        FILE_ID=$(echo "$RAW_LINK" | sed -E 's/.*(\/d\/|id=)([a-zA-Z0-9_-]+).*/\2/')
        if [[ -n "$FILE_ID" && "$FILE_ID" != "$RAW_LINK" ]]; then
            LINK="https://drive.google.com/uc?export=download&id=$FILE_ID"
        else
            LINK="$RAW_LINK"
        fi
    else
        LINK="Google Drive Link Generation Failed"
    fi

    [[ "$IS_CRON" != "cron" ]] && echo -e " \033[0;32m[+]\033[0m Transmitting to Telegram Bot..."

    CAPTION=$(echo -e "📦 <b>New OpenVPN Backup</b>\n\n📡 <b>IP:</b> <code>$IP</code>\n📅 <b>Date:</b> $DATE\n🔗 <b>Drive Link:</b> $LINK\n\n<i>Thanks for using TheTechSavage OpenVPN Manager</i>")

    TG_RESPONSE=$(curl -s -m 60 -X POST "https://api.telegram.org/bot$BOT_TOKEN/sendDocument" \
        -F chat_id="$CHAT_ID" \
        -F document=@"/root/$FILENAME" \
        -F caption="$CAPTION" \
        -F parse_mode="HTML")
        
    rm -rf "$BACKUP_DIR"
    rm -f /root/"$FILENAME"
    rm -f /tmp/backup_running
    
    if [[ "$IS_CRON" != "cron" ]]; then
        clear
        echo -e "\033[0;36m┌─────────────────────────────────────────────────────┐\033[0m"
        echo -e " \033[0;32mBACKUP COMPLETED!\033[0m"
        echo -e "\033[0;36m└─────────────────────────────────────────────────────┘\033[0m"
        echo -e " \033[0;33mDrive Link:\033[0m $LINK"
        
        if echo "$TG_RESPONSE" | grep -q '"ok":true'; then
            echo -e " \033[0;33mTelegram Bot:\033[0m \033[0;32mSuccessfully delivered to chat.\033[0m"
        else
            echo -e " \033[0;33mTelegram Bot:\033[0m \033[0;31mFAILED. Check bot token/chat ID.\033[0m"
        fi
        echo -e "\033[0;36m└─────────────────────────────────────────────────────┘\033[0m"
        read -n 1 -s -r -p "Press any key to return..."
        backup.sh
    fi
}

if [[ "$1" == "cron" ]]; then
    run_backup "cron"
    exit 0
fi

clear
if [ -f /etc/cron.d/auto_backup ]; then
    CRON_FREQ=$(grep "backup.sh" /etc/cron.d/auto_backup | awk '{print $2}')
    if [[ "$CRON_FREQ" == "*/12" ]]; then
        CRON_STAT="\033[0;32m[ACTIVE] (Every 12 Hours)\033[0m"
    else
        CRON_STAT="\033[0;32m[ACTIVE] (Every 24 Hours)\033[0m"
    fi
else
    CRON_STAT="\033[0;31m[OFF]\033[0m"
fi

echo -e "\033[0;36m┌─────────────────────────────────────────────────────┐\033[0m"
echo -e "\033[0;33m                SYSTEM BACKUP MANAGER                 \033[0m"
echo -e "\033[0;36m└─────────────────────────────────────────────────────┘\033[0m"
echo -e "  Auto-Backup Status: $CRON_STAT"
echo -e "\033[0;36m└─────────────────────────────────────────────────────┘\033[0m"
echo -e "    \033[0;32m[01]\033[0m  Run Manual Backup Now"
echo -e "    \033[0;32m[02]\033[0m  Set Auto-Backup (Every 12 Hours)"
echo -e "    \033[0;32m[03]\033[0m  Set Auto-Backup (Every 24 Hours)"
echo -e "    \033[0;32m[04]\033[0m  Turn OFF Auto-Backup"
echo -e "    \033[0;32m[05]\033[0m  Reset Telegram Credentials"
echo -e "    \033[0;32m[06]\033[0m  View Telegram Credentials"
echo -e "    \033[0;33m[07]\033[0m  Restore From Backup Link"
echo -e "\033[0;36m└─────────────────────────────────────────────────────┘\033[0m"
echo -e "    \033[0;31m[00]\033[0m  Back to Main Menu"
echo -e ""
read -p " Select menu : " opt

case $opt in
    1|01) run_backup "manual" ;;
    2|02) 
        check_credentials || { backup.sh; exit 1; }
        echo "30 */12 * * * root /usr/bin/backup.sh cron" > /etc/cron.d/auto_backup
        service cron restart
        echo -e " \033[0;32mAuto-Backup set to every 12 hours!\033[0m"
        sleep 2; backup.sh ;;
    3|03) 
        check_credentials || { backup.sh; exit 1; }
        echo "30 0 * * * root /usr/bin/backup.sh cron" > /etc/cron.d/auto_backup
        service cron restart
        echo -e " \033[0;32mAuto-Backup set to every 24 hours!\033[0m"
        sleep 2; backup.sh ;;
    4|04) 
        rm -f /etc/cron.d/auto_backup
        service cron restart
        echo -e " \033[0;31mAuto-Backup turned OFF.\033[0m"
        sleep 2; backup.sh ;;
    5|05)
        rm -f "$TG_CONF"
        echo -e " \033[0;32mCredentials cleared.\033[0m"
        sleep 2; backup.sh ;;
    6|06)
        clear
        echo -e "\033[0;36m┌─────────────────────────────────────────────────────┐\033[0m"
        echo -e "\033[0;33m               TELEGRAM CREDENTIALS                   \033[0m"
        echo -e "\033[0;36m└─────────────────────────────────────────────────────┘\033[0m"
        if [ -f "$TG_CONF" ]; then
            source "$TG_CONF"
            echo -e " \033[0;32mBOT TOKEN :\033[0m $BOT_TOKEN"
            echo -e " \033[0;32mCHAT ID   :\033[0m $CHAT_ID"
        else
            echo -e " \033[0;31m[!] No credentials saved yet.\033[0m"
        fi
        echo -e "\033[0;36m└─────────────────────────────────────────────────────┘\033[0m"
        read -n 1 -s -r -p "Press any key to return..."
        backup.sh ;;
    7|07) restore.sh ;;
    0|00) menu ;;
    *) echo "Invalid Option"; sleep 1; backup.sh ;;
esac