#!/bin/bash
/usr/bin/auth.sh || exit 1
RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[0;33m'
NC='\033[0m'

clear
echo -e "${CYAN}┌─────────────────────────────────────────────────────┐${NC}"
echo -e "${YELLOW}               SECURITY & LOCK MANAGER                ${NC}"
echo -e "${CYAN}└─────────────────────────────────────────────────────┘${NC}"
echo -e "  ${GREEN}[1]${NC} View Locked Accounts"
echo -e "  ${GREEN}[2]${NC} Manual Lock & Disconnect User"
echo -e "  ${GREEN}[3]${NC} Unlock User (Pardon)"
echo -e "${CYAN}└─────────────────────────────────────────────────────┘${NC}"
echo -e "  ${RED}[0]${NC} Back to OVPN Menu"
echo -e ""
read -p " Select Option : " req

case $req in
    1)
        clear
        echo -e "${CYAN}┌─────────────────────────────────────────────────────┐${NC}"
        echo -e "${RED}                 LOCKED ACCOUNTS                      ${NC}"
        echo -e "${CYAN}└─────────────────────────────────────────────────────┘${NC}"
        locked_count=0
        
        while IFS=: read -r username password uid gid info home shell; do
            if [[ "$uid" -ge 1000 && "$username" != "nobody" && "$shell" == "/bin/false" ]]; then
                status=$(passwd -S "$username" 2>/dev/null | awk '{print $2}')
                if [[ "$status" == "L" || "$status" == "LK" ]]; then
                    if [[ $locked_count -eq 0 ]]; then
                        echo -e " USERNAME"
                        echo -e "${CYAN}───────────────────────────────────────────────────────${NC}"
                    fi
                    echo -e " ${RED}$username${NC}"
                    ((locked_count++))
                fi
            fi
        done < /etc/passwd
        
        if [[ $locked_count -eq 0 ]]; then
            echo -e "  ${GREEN}No accounts are currently locked.${NC}"
        fi
        echo -e "${CYAN}└─────────────────────────────────────────────────────┘${NC}"
        read -n 1 -s -r -p "Press any key to return..."
        locker-ovpn
        ;;
    2)
        clear
        echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${YELLOW}            MANUAL LOCK USER              ${NC}"
        echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        
        tmp_users="/tmp/ovpn_unlocked.txt"
        > "$tmp_users"
        
        while IFS=: read -r username password uid gid info home shell; do
            if [[ "$uid" -ge 1000 && "$username" != "nobody" && "$shell" == "/bin/false" ]]; then
                status=$(passwd -S "$username" 2>/dev/null | awk '{print $2}')
                if [[ "$status" != "L" && "$status" != "LK" ]]; then
                    echo "$username" >> "$tmp_users"
                fi
            fi
        done < /etc/passwd
        
        if [[ ! -s "$tmp_users" ]]; then
            echo -e " ${GREEN}No active (unlocked) users found.${NC}"
            rm -f "$tmp_users"
            read -n 1 -s -r -p "Press any key to return..."
            locker-ovpn
            exit
        fi
        
        echo -e " NO   USER"
        echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        i=1
        while read -r u; do
            printf " %-4s %-15s\n" "$i." "$u"
            ((i++))
        done < "$tmp_users"
        echo -e " 0.   Back to Menu"
        echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        
        read -p " Select Number or Username : " input
        
        if [[ "$input" == "0" || "$input" == "00" || -z "$input" ]]; then
            rm -f "$tmp_users"
            locker-ovpn
            exit
        fi
        
        if grep -q -x "$input" "$tmp_users"; then
            user="$input"
        elif [[ "$input" =~ ^[0-9]+$ ]]; then
            user=$(sed -n "${input}p" "$tmp_users")
        else
            user=""
        fi
        
        if [[ -z "$user" ]]; then
            echo -e "${RED}[ERROR] Invalid selection.${NC}"
            rm -f "$tmp_users"
            sleep 2
            locker-ovpn
            exit
        fi
        rm -f "$tmp_users"
        
        passwd -l "$user" > /dev/null 2>&1
        echo "kill $user" | socat - TCP4:127.0.0.1:7505 > /dev/null 2>&1
        echo -e " ${GREEN}[+] User $user has been locked and disconnected!${NC}"
        sleep 2
        locker-ovpn
        ;;
    3)
        clear
        echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo -e "${YELLOW}              UNLOCK USER                 ${NC}"
        echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        
        tmp_users="/tmp/ovpn_locked.txt"
        > "$tmp_users"
        
        while IFS=: read -r username password uid gid info home shell; do
            if [[ "$uid" -ge 1000 && "$username" != "nobody" && "$shell" == "/bin/false" ]]; then
                status=$(passwd -S "$username" 2>/dev/null | awk '{print $2}')
                if [[ "$status" == "L" || "$status" == "LK" ]]; then
                    echo "$username" >> "$tmp_users"
                fi
            fi
        done < /etc/passwd
        
        if [[ ! -s "$tmp_users" ]]; then
            echo -e " ${GREEN}No accounts are currently locked.${NC}"
            rm -f "$tmp_users"
            read -n 1 -s -r -p "Press any key to return..."
            locker-ovpn
            exit
        fi
        
        echo -e " NO   USER"
        echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        i=1
        while read -r u; do
            printf " %-4s %-15s\n" "$i." "$u"
            ((i++))
        done < "$tmp_users"
        echo -e " 0.   Back to Menu"
        echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        
        read -p " Select Number or Username : " input
        
        if [[ "$input" == "0" || "$input" == "00" || -z "$input" ]]; then
            rm -f "$tmp_users"
            locker-ovpn
            exit
        fi
        
        if grep -q -x "$input" "$tmp_users"; then
            user="$input"
        elif [[ "$input" =~ ^[0-9]+$ ]]; then
            user=$(sed -n "${input}p" "$tmp_users")
        else
            user=""
        fi
        
        if [[ -z "$user" ]]; then
            echo -e "${RED}[ERROR] Invalid selection.${NC}"
            rm -f "$tmp_users"
            sleep 2
            locker-ovpn
            exit
        fi
        rm -f "$tmp_users"
        
        passwd -u "$user" > /dev/null 2>&1
        echo -e " ${GREEN}[+] User $user unlocked. They may now connect.${NC}"
        sleep 2
        locker-ovpn
        ;;
    0)
        menu-ovpn.sh
        ;;
    *)
        echo -e "${RED}Invalid Option${NC}"
        sleep 1
        locker-ovpn
        ;;
esac
