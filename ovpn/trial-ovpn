#!/bin/bash
/usr/bin/auth.sh || exit 1
clear
RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${GREEN}       GENERATE OPENVPN TRIAL ACCOUNT     ${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

# 1. Generate Random Trial User
rand=$(</dev/urandom tr -dc 0-9 | head -c4)
Login="Trial-$rand"
Pass="1"
limit=1
masaaktif=1

# Failsafe duplicate check
if getent passwd "$Login" > /dev/null 2>&1; then
    rand2=$(</dev/urandom tr -dc 0-9 | head -c4)
    Login="Trial-$rand2"
fi

exp_date=$(date -d "$masaaktif days" +"%b %d, %Y")
expe=$(date -d "$masaaktif days" +"%Y-%m-%d")

# 2. Create System User
useradd -e "$expe" -s /bin/false -M "$Login"
echo -e "$Pass\n$Pass\n" | passwd "$Login" &> /dev/null

# 3. Save Limit
mkdir -p /etc/openvpn/limit
echo "$limit" > /etc/openvpn/limit/$Login

MYIP=$(curl -sS -4 ifconfig.me)

# 4. Print Receipt
clear
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${GREEN}         OPENVPN TRIAL GENERATED          ${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e " Username    : ${GREEN}$Login${NC}"
echo -e " Password    : ${GREEN}$Pass${NC}"
echo -e " Max Login   : ${GREEN}$limit Connection(s)${NC}"
echo -e " Expired On  : ${RED}$exp_date${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e " Server IP   : ${GREEN}$MYIP${NC}"
echo -e " Config File : ${GREEN}http://$MYIP:85/Universal-Client.ovpn${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
read -n 1 -s -r -p "Press any key to return..."
menu-ovpn.sh