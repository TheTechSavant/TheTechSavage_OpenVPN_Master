#!/bin/bash
# --- TheTechSavage Silent OVPN API ---
/usr/bin/auth.sh || exit 1

Login=$1
Pass=$2
limit=$3
masaaktif=$4

if [[ -z "$Login" || -z "$Pass" || -z "$limit" || -z "$masaaktif" ]]; then
    echo "Error: Missing API arguments. Usage: api-ovpn [User] [Pass] [Limit] [Days]"
    exit 1
fi

IP=$(curl -sS -4 ifconfig.me)
exp_date=$(date -d "$masaaktif days" +"%b %d, %Y")
expe=$(date -d "$masaaktif days" +"%Y-%m-%d")

# Create User Silently
useradd -e "$expe" -s /bin/false -M "$Login"
echo -e "$Pass\n$Pass\n" | passwd "$Login" &> /dev/null

# Save Limit for AutoKill
mkdir -p /etc/openvpn/limit
echo "$limit" > /etc/openvpn/limit/$Login

# Output for Telegram Bot
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "      PREMIUM OPENVPN ACCOUNT      "
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
printf "%-13s : %s\n" "Username" "$Login"
printf "%-13s : %s\n" "Password" "$Pass"
printf "%-13s : %s Connection(s)\n" "Max Login" "$limit"
printf "%-13s : %s\n" "Expired On" "$exp_date"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
printf "%-13s : %s\n" "Server IP" "$IP"
printf "%-13s : %s\n" "Config Link" "http://$IP:85/Universal-Client.ovpn"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "⚠️ DISCLAIMER:"
echo "This account is strictly limited to $limit concurrent connection(s)."
echo "Multi-login will trigger our Sniper AutoKill system."
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
