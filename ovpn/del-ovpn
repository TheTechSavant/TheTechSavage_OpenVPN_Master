#!/bin/bash
/usr/bin/auth.sh || exit 1
clear
RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m'

echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${RED}          DELETE OPENVPN ACCOUNT          ${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

tmp_users="/tmp/ovpn_del.txt"
> "$tmp_users"

while IFS=: read -r username password uid gid info home shell; do
    if [[ "$uid" -ge 1000 && "$username" != "nobody" && "$shell" == "/bin/false" ]]; then
        exp_raw=$(chage -l "$username" | grep "Account expires" | cut -d: -f2 | sed 's/^ //g')
        if [[ "$exp_raw" == "never" ]]; then
            exp_display="Lifetime"
        else
            exp_display=$(date -d "$exp_raw" "+%d-%b-%Y" 2>/dev/null)
        fi
        echo "$username|$exp_display" >> "$tmp_users"
    fi
done < /etc/passwd

if [[ ! -s "$tmp_users" ]]; then
    echo -e "${RED}Error: No OpenVPN users found to delete!${NC}"
    rm -f "$tmp_users"
    read -n 1 -s -r -p "Press any key to return..."
    menu-ovpn.sh
    exit 1
fi

echo -e " NO   USER          EXPIRES"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
i=1
while IFS='|' read -r user exp; do
    printf " %-4s %-13s %-10s\n" "$i." "$user" "$exp"
    ((i++))
done < "$tmp_users"
echo -e " 0.   Back to Menu"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

read -p " Select Number or Username : " input

if [[ "$input" == "0" || "$input" == "00" || -z "$input" ]]; then
    rm -f "$tmp_users"
    menu-ovpn.sh
    exit 0
fi

if grep -q "^${input}|" "$tmp_users"; then
    user=$(grep "^${input}|" "$tmp_users" | head -n 1 | cut -d'|' -f1)
elif [[ "$input" =~ ^[0-9]+$ ]]; then
    user=$(sed -n "${input}p" "$tmp_users" | cut -d'|' -f1)
else
    if grep -q "^${input}|" "$tmp_users" || grep -q "^${input}$" <<< "$(cut -d'|' -f1 $tmp_users)"; then
        user=$(grep -E "^${input}\|" "$tmp_users" | head -n 1 | cut -d'|' -f1)
    else
        user=""
    fi
fi

if [[ -z "$user" ]]; then
    echo -e "${RED}[ERROR] Invalid selection. Please try again.${NC}"
    rm -f "$tmp_users"
    sleep 2
    del-ovpn
    exit 1
fi
rm -f "$tmp_users"

# Execute Deletion
echo "kill $user" | socat - TCP4:127.0.0.1:7505 > /dev/null 2>&1
pkill -u "$user" > /dev/null 2>&1
userdel -f "$user" > /dev/null 2>&1
rm -f /etc/openvpn/limit/$user

echo -e "\n ${GREEN}[OK] User $user has been deleted and disconnected.${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
read -n 1 -s -r -p "Press any key to return..."
menu-ovpn.sh
