#!/bin/bash
/usr/bin/auth.sh || exit 1
clear
RED='\033[0;31m'
NC='\033[0m'
GREEN='\033[0;32m'
ORANGE='\033[0;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
YELLOW='\033[0;33m'

echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${YELLOW}           RENEW OPENVPN ACCOUNT          ${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

# 1. GATHER ACTIVE OPENVPN USERS
tmp_users="/tmp/ovpn_renew.txt"
> "$tmp_users"

while IFS=: read -r username password uid gid info home shell; do
    # Only pull real accounts assigned to the restricted VPN shell
    if [[ "$uid" -ge 1000 && "$username" != "nobody" && "$shell" == "/bin/false" ]]; then
        exp_raw=$(chage -l "$username" | grep "Account expires" | cut -d: -f2 | sed 's/^ //g')
        if [[ "$exp_raw" == "never" ]]; then
            exp_display="Lifetime"
        else
            exp_display=$(date -d "$exp_raw" "+%d-%b-%Y" 2>/dev/null)
        fi
        echo "$username|$exp_display" >> "$tmp_users"
    fi
done < /etc/passwd

if [[ ! -s "$tmp_users" ]]; then
    echo -e "${RED}Error: No OpenVPN users found to renew!${NC}"
    rm -f "$tmp_users"
    read -n 1 -s -r -p "Press any key to return..."
    menu-ovpn.sh
    exit 1
fi

# 2. DISPLAY LISTED USERS WITH INDEX NUMBERS
echo -e " NO   USER          EXPIRES"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
i=1
while IFS='|' read -r user exp; do
    printf " %-4s %-13s %-10s\n" "$i." "$user" "$exp"
    ((i++))
done < "$tmp_users"
echo -e " 0.   Back to Menu"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

read -p " Select Number or Username : " input

# 3. HANDLE BACK SELECTION OR EMPTY INPUT
if [[ "$input" == "0" || "$input" == "00" || -z "$input" ]]; then
    rm -f "$tmp_users"
    menu-ovpn.sh
    exit 0
fi

# 4. SMART HYBRID LOGIC MATCHING
if grep -q "^${input}|" "$tmp_users"; then
    selected_line=$(grep "^${input}|" "$tmp_users" | head -n 1)
    user=$(echo "$selected_line" | cut -d'|' -f1)
    exp=$(echo "$selected_line" | cut -d'|' -f2)
elif [[ "$input" =~ ^[0-9]+$ ]]; then
    selected_line=$(sed -n "${input}p" "$tmp_users")
    user=$(echo "$selected_line" | cut -d'|' -f1)
    exp=$(echo "$selected_line" | cut -d'|' -f2)
else
    # Check if input matches username natively without number index
    if grep -q "^${input}|" "$tmp_users" || grep -q "^${input}$" <<< "$(cut -d'|' -f1 $tmp_users)"; then
        selected_line=$(grep -E "^${input}\|" "$tmp_users" | head -n 1)
        user=$(echo "$selected_line" | cut -d'|' -f1)
        exp=$(echo "$selected_line" | cut -d'|' -f2)
    else
        user=""
    fi
fi

if [[ -z "$user" ]]; then
    echo -e "${RED}[ERROR] Invalid selection. Please try again.${NC}"
    rm -f "$tmp_users"
    sleep 2
    renew-ovpn
    exit 1
fi

rm -f "$tmp_users"

if [[ "$exp" == "Lifetime" ]]; then
    echo -e "${RED}[ERROR] Cannot extend or modify a Lifetime admin account!${NC}"
    sleep 2
    menu-ovpn.sh
    exit 1
fi

# 5. INPUT RENEWAL DURATION
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e " Target User   : ${GREEN}$user${NC}"
read -p " Add Days      : " days
[[ -z "$days" ]] && days=30

# 6. CALCULATE TIME DIFFERENTIALS SECURELY
now=$(date +%Y-%m-%d)
exp_raw_current=$(chage -l "$user" | grep "Account expires" | cut -d: -f2 | sed 's/^ //g')
d1=$(date -d "$exp_raw_current" +%s 2>/dev/null)
d2=$(date -d "$now" +%s)

# If account is still active, append days onto existing expiry. If already expired, start fresh from today.
if [[ $d1 -ge $d2 ]]; then
    new_exp=$(date -d "$exp_raw_current + $days days" +"%Y-%m-%d")
else
    new_exp=$(date -d "$now + $days days" +"%Y-%m-%d")
fi

# Apply to Linux shadow structure
chage -E "$new_exp" "$user"

# 7. PRINT RE-VALIDATED RECEIPT
clear
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${ORANGE}        OPENVPN ACCOUNT RENEWED           ${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e " Username    : ${GREEN}$user${NC}"
echo -e " Days Added  : ${GREEN}$days Days${NC}"
echo -e " Old Expiry  : ${RED}$exp${NC}"
echo -e " New Expiry  : ${GREEN}$(date -d "$new_exp" "+%d-%b-%Y")${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
read -n 1 -s -r -p "Press any key to return..."
menu-ovpn.sh
