#!/bin/bash
/usr/bin/auth.sh || exit 1

LOG="/var/log/openvpn-status.log"

if [[ ! -f "$LOG" ]]; then
    exit 0
fi

# Count occurrences of each username from the active connections log
grep -E "^[a-zA-Z0-9_-]+,[0-9]{1,3}\." "$LOG" | cut -d',' -f1 | sort | uniq -c > /tmp/ovpn_counts.txt

while read count user; do
    limit=1
    if [[ -f "/etc/openvpn/limit/$user" ]]; then
        limit=$(cat "/etc/openvpn/limit/$user")
    fi
    
    # If the user has more connections than allowed
    if [[ "$count" -gt "$limit" ]]; then
        
        # 1. Lock the PAM account temporarily so they can't immediately re-authenticate
        passwd -l "$user" > /dev/null 2>&1
        
        # 2. Drop their active OpenVPN sessions via the Management Interface
        echo "kill $user" | socat - TCP4:127.0.0.1:7505 > /dev/null 2>&1
        
        # 3. Log the violation
        echo "$(date '+%Y-%m-%d %H:%M:%S') : Kicked $user for multi-login ($count/$limit)" >> /var/log/ovpn-sniper.log
        
        # 4. The Sin Bin: Auto-unlock in 5 minutes in the background
        (sleep 300 && passwd -u "$user" > /dev/null 2>&1) &
    fi
done < /tmp/ovpn_counts.txt

rm -f /tmp/ovpn_counts.txt
