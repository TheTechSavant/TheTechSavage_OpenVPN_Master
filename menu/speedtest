#!/bin/bash
/usr/bin/auth.sh || exit 1
if [[ "$(cat /tmp/.vps_auth_token 2>/dev/null)" != "TechSavage_$(date +%Y-%m-%d)" ]]; then exit 1; fi
clear
CYAN='\033[0;36m'
YELLOW='\033[0;33m'
GREEN='\033[0;32m'
NC='\033[0m'
RED='\033[0;31m'

echo -e "${CYAN}┌─────────────────────────────────────────────────────┐${NC}"
echo -e "${YELLOW}                 OOKLA SPEEDTEST                      ${NC}"
echo -e "${CYAN}└─────────────────────────────────────────────────────┘${NC}"

# 1. Remove the old python version if it's still lingering
if command -v speedtest-cli &> /dev/null; then
    echo -e " ${YELLOW}Cleaning up old speedtest packages...${NC}"
    apt-get remove speedtest-cli -y > /dev/null 2>&1
fi

# 2. Safely extract and rename the binary so it doesn't overwrite this script!
if [ ! -f "/usr/bin/ookla-speedtest" ]; then
    echo -e " ${GREEN}Downloading Official Ookla Binary...${NC}"
    wget -q -O /tmp/speedtest.tgz https://install.speedtest.net/app/cli/ookla-speedtest-1.2.0-linux-x86_64.tgz
    # Extract to /tmp first
    tar -xzf /tmp/speedtest.tgz -C /tmp/ speedtest > /dev/null 2>&1
    # Rename and move to /usr/bin safely
    mv /tmp/speedtest /usr/bin/ookla-speedtest
    chmod +x /usr/bin/ookla-speedtest
    rm -f /tmp/speedtest.tgz
fi

clear
echo -e "${CYAN}┌─────────────────────────────────────────────────────┐${NC}"
echo -e "${YELLOW}                 OOKLA SPEEDTEST                      ${NC}"
echo -e "${CYAN}└─────────────────────────────────────────────────────┘${NC}"

# 3. Run the renamed official binary
if [ ! -f "/usr/bin/ookla-speedtest" ]; then
    echo -e " ${RED}[ERROR] Speedtest binary failed to install.${NC}"
else
    ookla-speedtest --accept-license --accept-gdpr
fi

echo -e "${CYAN}└─────────────────────────────────────────────────────┘${NC}"
read -n 1 -s -r -p "Press any key to return..." || exit 1
menu-set.sh