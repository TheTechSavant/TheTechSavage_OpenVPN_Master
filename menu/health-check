#!/bin/bash
/usr/bin/auth.sh || exit 1
clear
RED='\033[0;31m'
NC='\033[0m'
GREEN='\033[0;32m'
ORANGE='\033[0;33m'
CYAN='\033[0;36m'

echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e "${ORANGE}      SERVER HEALTH & STATUS CHECK        ${NC}"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

# 1. CHECK CORE ENGINE
if systemctl is-active --quiet openvpn-server@server; then
    echo -e " OpenVPN Engine : ${GREEN}[RUNNING]${NC}"
else
    echo -e " OpenVPN Engine : ${RED}[STOPPED]${NC} (Check logs!)"
fi

if systemctl is-active --quiet nginx; then
    echo -e " Nginx File Hub : ${GREEN}[RUNNING]${NC}"
else
    echo -e " Nginx File Hub : ${RED}[STOPPED]${NC}"
fi

# 2. CHECK CONFIGURATIONS
if [[ -s /etc/openvpn/server/server.conf ]]; then
    echo -e " Server Config  : ${GREEN}[OK]${NC} Found"
else
    echo -e " Server Config  : ${RED}[FAIL]${NC} Missing"
fi

if [[ -s /root/Universal-Client.ovpn ]]; then
    echo -e " Universal OVPN : ${GREEN}[OK]${NC} Generated"
else
    echo -e " Universal OVPN : ${RED}[FAIL]${NC} Missing"
fi

# 3. CHECK CRITICAL SCRIPTS
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e " SCRIPT INTEGRITY CHECK:"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

check_script() {
    if [[ -x /usr/bin/$1 ]]; then
        echo -e " $1 : ${GREEN}[OK]${NC}"
    else
        echo -e " $1 : ${RED}[MISSING/BAD PERM]${NC}"
    fi
}

check_script "add-ovpn"
check_script "del-ovpn"
check_script "renew-ovpn"
check_script "member-ovpn"
check_script "cek-ovpn"
check_script "ovpn-sniper"
check_script "ovpn-xp"

# 4. CHECK LIMIT DIRECTORIES & CRONJOBS
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e " DATABASE & AUTOMATION CHECK:"
echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

if [[ -d /etc/openvpn/limit ]]; then echo -e " Limit Database : ${GREEN}[OK]${NC}"; else echo -e " Limit Database : ${RED}[MISSING]${NC}"; fi
if [[ -f /etc/cron.d/ovpn-sniper ]]; then echo -e " AutoKill Cron  : ${GREEN}[ACTIVE]${NC}"; else echo -e " AutoKill Cron  : ${RED}[MISSING]${NC}"; fi
if [[ -f /etc/cron.d/ovpn-xp ]]; then echo -e " AutoExpiry Cron: ${GREEN}[ACTIVE]${NC}"; else echo -e " AutoExpiry Cron: ${RED}[MISSING]${NC}"; fi

echo -e "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
echo -e " ${GREEN}Scan Complete.${NC}"
read -n 1 -s -r -p "Press any key to exit..."
menu-set.sh
