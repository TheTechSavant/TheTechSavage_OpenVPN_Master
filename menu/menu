#!/bin/bash
/usr/bin/auth.sh || exit 1
if [[ "$(cat /tmp/.vps_auth_token 2>/dev/null)" != "TechSavage_$(date +%Y-%m-%d)" ]]; then exit 1; fi

# Color Settings
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
YELLOW='\033[0;33m'
NC='\033[0m'

MYIP=$(curl -sS -4 ifconfig.me)
OS_NAME=$(grep -w "PRETTY_NAME" /etc/os-release | cut -d= -f2 | tr -d '"')
UPTIME=$(uptime -p | cut -d " " -f 2-10)
DATE=$(date +"%d-%m-%Y | %H:%M:%S")

# CPU & RAM
cpu_idle=$(top -bn1 | grep "Cpu(s)" | sed 's/,/./g' | grep -Po "[0-9.]+(?=\s*id)" | head -n 1)
cpu_usage=$(awk "BEGIN {printf \"%.1f%%\", 100 - ${cpu_idle:-0}}")

RAM_TOTAL=$(free -m | grep Mem | awk '{print $2}')
RAM_USED=$(free -m | grep Mem | awk '{print $3}')
RAM_FREE=$(($RAM_TOTAL - $RAM_USED))

# REBOOT TIME
if [ -f /etc/cron.d/auto_reboot ]; then
    cron_hr=$(grep 'reboot' /etc/cron.d/auto_reboot | awk '{print $2}')
    if [[ "$cron_hr" == "*" ]]; then
        REBOOT_TIME="Every 1 Hour"
    elif [[ "$cron_hr" == "*/6" ]]; then
        REBOOT_TIME="Every 6 Hours"
    elif [[ "$cron_hr" == "*/12" ]]; then
        REBOOT_TIME="Every 12 Hours"
    elif [[ "$cron_hr" =~ ^[0-9]+$ ]]; then
        printf -v formatted_time "%02d:00" "$cron_hr"
        REBOOT_TIME="$formatted_time (Daily)"
    else
        REBOOT_TIME="Active (Custom)"
    fi
else
    REBOOT_TIME="Not Set"
fi

# COUNTERS
OVPN_COUNT=$(awk -F: '$3 >= 1000 && $1 != "nobody" && $7 == "/bin/false" {print $1}' /etc/passwd | wc -l)

status_check() {
    if systemctl is-active --quiet "$1"; then
        echo -e "${GREEN}ON${NC}"
    else
        echo -e "${RED}OFF${NC}"
    fi
}

# BANDWIDTH MONITOR
IFACE=$(ip route get 1.1.1.1 | awk '{print $5; exit}')
CURRENT_MONTH=$(date +%Y-%m)
RX_TODAY=$(vnstat -i $IFACE | grep "today" | awk '{print $2" "$3}' || echo "0 B")
RX_YEST=$(vnstat -i $IFACE | grep "yesterday" | awk '{print $2" "$3}' || echo "0 B")
RX_MONTH=$(vnstat -i $IFACE -m | grep "$CURRENT_MONTH" | awk '{print $8" "$9}' || echo "0 B")

# LICENSE CALCULATION
CLIENT=$(cat /etc/openvpn/client_name 2>/dev/null || echo "Unknown")
EXP=$(cat /etc/openvpn/exp_date 2>/dev/null || echo "Unknown")

if [[ "$EXP" == "LIFETIME" ]]; then
    DAYS_LEFT="Unlimited"
elif [[ "$EXP" != "Unknown" ]]; then
    NOW=$(date +%s)
    EXP_FORMATTED=$(echo "$EXP" | awk -F'-' '{print $3"-"$2"-"$1}')
    EXP_SEC=$(date -d "$EXP_FORMATTED" +%s 2>/dev/null)
    DAYS_LEFT=$(( ($EXP_SEC - $NOW) / 86400 ))
    if [[ $DAYS_LEFT -lt 0 ]]; then DAYS_LEFT=0; fi
else
    DAYS_LEFT="0"
fi

clear
echo -e "${CYAN}┌─────────────────────────────────────────────────────┐${NC}"
echo -e "${YELLOW}                 LICENSE INFORMATION                  ${NC}"
echo -e "${CYAN}└─────────────────────────────────────────────────────┘${NC}"
echo -e "   Client     : ${GREEN}$CLIENT${NC}"
echo -e "   Expiry Date: ${GREEN}$EXP${NC}"
echo -e "   Days Left  : ${GREEN}$DAYS_LEFT Days${NC}"
echo -e "${CYAN}┌─────────────────────────────────────────────────────┐${NC}"
echo -e "${YELLOW}                   VPS INFORMATION                    ${NC}"
echo -e "${CYAN}└─────────────────────────────────────────────────────┘${NC}"
echo -e "   Server Uptime      = $UPTIME"
echo -e "   Current Time       = $DATE"
echo -e "   Operating System   = $OS_NAME"
echo -e "   Total Ram          = $RAM_TOTAL MB"
echo -e "   Total Used Ram     = $RAM_USED MB"
echo -e "   Total Free Ram     = $RAM_FREE MB"
echo -e "   CPU Usage          = $cpu_usage"
echo -e "   Time Reboot VPS    = $REBOOT_TIME"
echo -e "${CYAN}┌─────────────────────────────────────────────────────┐${NC}"
echo -e "${YELLOW}         @THETECHSAVAGETELEGRAM OPENVPN MANAGER          ${NC}"
echo -e "${CYAN}└─────────────────────────────────────────────────────┘${NC}"
echo -e "${CYAN}┌─────────────────────────────────────────────────────┐${NC}"
echo -e "    Use Core          : OpenVPN (Standalone Engine)"
echo -e "    IP-VPS            : $MYIP"
echo -e "${CYAN}└─────────────────────────────────────────────────────┘${NC}"
echo -e "${CYAN}┌─────────────────────────────────────────────────────┐${NC}"
echo -e "  THANKS FOR USING @THETECHSAVAGETELEGRAM AUTOSCRIPT "
echo -e "${CYAN}└─────────────────────────────────────────────────────┘${NC}"
echo -e "${CYAN}┌─────────────────────────────────────────────────────┐${NC}"
echo -e "                    OPENVPN USERS"
echo -e "                         ${GREEN}$OVPN_COUNT${NC}"
echo -e "${CYAN}└─────────────────────────────────────────────────────┘${NC}"
echo -e "${CYAN}┌─────────────────────────────────────────────────────┐${NC}"
echo -e "       OPENVPN : $(status_check openvpn-server@server)      NGINX : $(status_check nginx)      CRON : $(status_check cron)"
echo -e "${CYAN}└─────────────────────────────────────────────────────┘${NC}"
echo -e "${CYAN}┌─────────────────────────────────────────────────────┐${NC}"
echo -e "    ${GREEN}[01]${NC} OpenVPN Manager     ${GREEN}[03]${NC} Backup/Restore"
echo -e "    ${GREEN}[02]${NC} Settings & Health   ${RED}[00]${NC} EXIT SYSTEM"
echo -e "${CYAN}└─────────────────────────────────────────────────────┘${NC}"
echo -e "${CYAN}┌─────────────────────────────────────────────────────┐${NC}"
echo -e "${YELLOW}                 MONITORING BANDWIDTH                 ${NC}"
echo -e "${CYAN}├─────────────────────────────────────────────────────┤${NC}"
echo -e "   BANDWIDTH USED TODAY       = ${GREEN}$RX_TODAY${NC}"
echo -e "   BANDWIDTH USED YESTERDAY   = ${GREEN}$RX_YEST${NC}"
echo -e "   TOTAL BANDWIDTH THIS MONTH = ${GREEN}$RX_MONTH${NC}"
echo -e "${CYAN}└─────────────────────────────────────────────────────┘${NC}"
echo -e ""
read -p " Select menu : " opt || exit 1
case $opt in
    1|01) menu-ovpn.sh ;;
    2|02) menu-set.sh ;;
    3|03) backup.sh ;;
    0|00) clear; exit 0 ;;
    *) echo "Invalid Option"; sleep 1; menu ;;
esac
